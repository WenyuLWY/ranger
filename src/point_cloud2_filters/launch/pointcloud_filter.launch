<launch>
    <node pkg="sensor_filters" type="pointcloud2_filter_chain" output="screen" name="pointcloud2_filters">
        <remap from="~input" to="/cloud_all_fields_fullframe" />
        <remap from="~output" to="/cloud_all_fields_fullframe/filtered" />
        <rosparam command="load" file="$(find point_cloud2_filters)/config/pointcloud_filter.yaml" />
    </node>
</launch>