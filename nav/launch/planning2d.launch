<launch>

  <arg name="raw_cloud_topic"               default="/velodyne_points"/> 
  <arg name="cmd_vel"                     default="cmd_vel"/> 
  <arg name="no_static_map"               default="false"/>





   <!-- 雷达到footprint高度为0.541m. -->
  <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
    <!-- <param name="min_height" value="-0.5"/> -->
    <!-- <param name="max_height " value="1"/> -->
    <param name="min_height" value="-0.3"/>
    <param name="max_height " value="0.3"/>

    <param name="target_frame" value="velodyne"/>
    <!-- <param name="range_min" value="0.1"/>
    <param name="range_max" value="100"/> -->
    <param name ="concurrency_level" value="1"/>
    <!-- <param name ="scan_time" value="0.2"/> -->
    <!-- <param name ="angle_increment" value="0.00087"/> -->
    <!-- <param name ="angle_min" value="-3.14"/>
    <param name ="angle_max" value="3.14"/> -->
    <remap from="cloud_in" to="$(arg raw_cloud_topic)"/>
    <remap from="scan" to="/scan_2d"/>
  </node>


 
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">

    <param name="base_global_planner"    value="global_planner/GlobalPlanner"/>
    <!-- <param name="base_global_planner"    value="navfn/NavfnROS"/> -->
    <!--  global_planner/GlobalPlanner -->
    <!-- <param name="base_local_planner"   value="dwa_local_planner/DWAPlannerROS"/>  -->
    <param name="base_local_planner"   value="teb_local_planner/TebLocalPlannerROS"/> 

    <param name="global_frame_id" value="map" />
    <param name="odom_frame_id" value="odom" />
    <param name="base_frame_id" value="base_link" />
    


    <!-- observation sources located in costmap_common.yaml -->
    <rosparam file="$(find nav)/config/move_base_sim/costmap_common.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find nav)/config/move_base_sim/costmap_common.yaml" command="load" ns="local_costmap" />

    <!-- local costmap, needs size -->
    <rosparam file="$(find nav)/config/move_base_sim/global_costmap.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find nav)/config/move_base_sim/local_costmap.yaml" command="load" ns="local_costmap" />

    <rosparam file="$(find nav)/config/move_base_sim/move_base_params.yaml" command="load" />
    <rosparam file="$(find nav)/config/move_base_sim/global_planner.yaml" command="load" />

    <rosparam file="$(find nav)/config/move_base_sim/teb_local_planner_test.yaml" command="load" />
    
    <!-- <rosparam file="$(find nav)/config/move_base_sim/teb_local_planner.yaml" command="load" /> -->

    <remap from="cmd_vel" to="$(arg cmd_vel)"/>

  </node>

</launch>