<?xml version="1.0"?>'
<launch>
  <!-- common -->
  <arg name="sensorOffsetX" default="0"/>
  <arg name="sensorOffsetY" default="0"/>
  <arg name="vehicleLength" default="0.6"/>
  <arg name="vehicleWidth" default="0.6"/>
  <arg name="maxSpeed" default="2.0"/>
  <arg name="maxAccel" default="2.5"/>

  <!-- terrain_analysis -->
  <arg name="useSorting" default="false"/>
  <arg name="quantileZ" default="0.25"/>
  <arg name="considerDrop" default="true"/>
  <arg name="limitGroundLift" default="false"/>
  <arg name="maxGroundLift" default="0.15"/>
  <arg name="vehicleHeight" default="1.5"/>
  <arg name="minRelZ" default="-2.5"/>
  <arg name="maxRelZ" default="1.0"/>

  <!-- terrain_analysis_ext -->
  <arg name="checkTerrainConn" default="false"/>

  <!-- local_planner -->
  <arg name="twoWayDrive" default="true"/>
  <arg name="obstacleHeightThre" default="0.15"/>
  <arg name="groundHeightThre" default="0.1"/>

  <!-- pathFollower -->
  <arg name="cmd_vel_topic" default="/cmd_vel"/>
  <arg name="lookAheadDis" default="0.5"/>
  <arg name="maxYawRate" default="45"/>
  <arg name="noRotAtStop" default="false"/>
  <arg name="noRotAtGoal" default="true"/>
  <arg name="dirDiffThre" default="0.1"/>
  <arg name="stopDisThre" default="0.2"/>
  <arg name="slowDwnDisThre" default="0.85"/>

  <!-- others -->
  <arg name="cameraOffsetZ" default="0"/>
  <arg name="autonomyMode" default="true"/>
  <arg name="autonomySpeed" default="2.0"/>
  <arg name="joyToSpeedDelay" default="2.0"/>
  <arg name="goalX" default="0"/>
  <arg name="goalY" default="0"/>

  <node pkg="terrain_analysis" type="terrainAnalysis" name="terrainAnalysis" output="screen" required="true">
    <param name="scanVoxelSize" type="double" value="0.05" />
    <param name="decayTime" type="double" value="2.0" />
    <param name="noDecayDis" type="double" value="4.0" />
    <param name="clearingDis" type="double" value="8.0" />
    <param name="useSorting" type="bool" value="$(arg useSorting)" />
    <param name="quantileZ" type="double" value="$(arg quantileZ)" />
    <param name="considerDrop" type="bool" value="$(arg considerDrop)" />
    <param name="limitGroundLift" type="bool" value="$(arg limitGroundLift)" />
    <param name="maxGroundLift" type="double" value="$(arg maxGroundLift)" />
    <param name="clearDyObs" type="bool" value="true" />
    <param name="minDyObsDis" type="double" value="0.3" />
    <param name="minDyObsAngle" type="double" value="0" />
    <param name="minDyObsRelZ" type="double" value="-0.5" />
    <param name="absDyObsRelZThre" type="double" value="0.2" />
    <param name="minDyObsVFOV" type="double" value="-16.0" />
    <param name="maxDyObsVFOV" type="double" value="16.0" />
    <param name="minDyObsPointNum" type="int" value="1" />
    <param name="noDataObstacle" type="bool" value="false" />
    <param name="noDataBlockSkipNum" type="int" value="0" />
    <param name="minBlockPointNum" type="int" value="10" />
    <param name="vehicleHeight" type="double" value="$(arg vehicleHeight)" />
    <param name="voxelPointUpdateThre" type="int" value="100" />
    <param name="voxelTimeUpdateThre" type="double" value="2.0" />
    <param name="minRelZ" type="double" value="$(arg minRelZ)" />
    <param name="maxRelZ" type="double" value="$(arg maxRelZ)" />
    <param name="disRatioZ" type="double" value="0.2" />
  </node>

  <node pkg="terrain_analysis_ext" type="terrainAnalysisExt" name="terrainAnalysisExt" output="screen" required="true">
    <param name="scanVoxelSize" type="double" value="0.1" />
    <param name="decayTime" type="double" value="10.0" />
    <param name="noDecayDis" type="double" value="0" />
    <param name="clearingDis" type="double" value="30.0" />
    <param name="useSorting" type="bool" value="false" />
    <param name="quantileZ" type="double" value="0.1" />
    <param name="vehicleHeight" type="double" value="$(arg vehicleHeight)" />
    <param name="voxelPointUpdateThre" type="int" value="100" />
    <param name="voxelTimeUpdateThre" type="double" value="2.0" />
    <param name="lowerBoundZ" type="double" value="-2.5" />
    <param name="upperBoundZ" type="double" value="1.0" />
    <param name="disRatioZ" type="double" value="0.1" />
    <param name="checkTerrainConn" type="bool" value="$(arg checkTerrainConn)" />
    <param name="terrainConnThre" type="double" value="0.5" />
    <param name="terrainUnderVehicle" type="double" value="-0.75" />
    <param name="ceilingFilteringThre" type="double" value="2.0" />
    <param name="localTerrainMapRadius" type="double" value="4.0" />
  </node>

  <node pkg="local_planner" type="localPlanner" name="localPlanner" output="screen" required="true">
    <param name="pathFolder" type="string" value="$(find local_planner)/paths" />
    <param name="vehicleLength" type="double" value="$(arg vehicleLength)" />
    <param name="vehicleWidth" type="double" value="$(arg vehicleWidth)" />
    <param name="sensorOffsetX" value="$(arg sensorOffsetX)" />
    <param name="sensorOffsetY" value="$(arg sensorOffsetY)" />
    <param name="twoWayDrive" value="$(arg twoWayDrive)" />
    <param name="laserVoxelSize" type="double" value="0.05" />
    <param name="terrainVoxelSize" type="double" value="0.2" />
    <param name="useTerrainAnalysis" type="bool" value="true" />
    <param name="checkObstacle" type="bool" value="true" />
    <param name="checkRotObstacle" type="bool" value="false" />
    <param name="adjacentRange" type="double" value="4.25" />
    <param name="obstacleHeightThre" type="double" value="$(arg obstacleHeightThre)" />
    <param name="groundHeightThre" type="double" value="$(arg groundHeightThre)" />
    <param name="costHeightThre" type="double" value="0.1" />
    <param name="costScore" type="double" value="0.02" />
    <param name="useCost" type="bool" value="false" />
    <param name="pointPerPathThre" type="int" value="2" />
    <param name="minRelZ" type="double" value="$(arg minRelZ)" />
    <param name="maxRelZ" type="double" value="$(arg maxRelZ)" />
    <param name="maxSpeed" value="$(arg maxSpeed)" />
    <param name="dirWeight" type="double" value="0.02" />
    <param name="dirThre" type="double" value="90.0" />
    <param name="dirToVehicle" type="bool" value="false" />
    <param name="pathScale" type="double" value="1.25" />
    <param name="minPathScale" type="double" value="0.75" />
    <param name="pathScaleStep" type="double" value="0.25" />
    <param name="pathScaleBySpeed" type="bool" value="true" />
    <param name="minPathRange" type="double" value="1.0" />
    <param name="pathRangeStep" type="double" value="0.5" />
    <param name="pathRangeBySpeed" type="bool" value="true" />
    <param name="pathCropByGoal" type="bool" value="true" />
    <param name="autonomyMode" value="$(arg autonomyMode)" />
    <param name="autonomySpeed" value="$(arg autonomySpeed)" />
    <param name="joyToSpeedDelay" value="$(arg joyToSpeedDelay)" />
    <param name="joyToCheckObstacleDelay" type="double" value="5.0" />
    <param name="goalClearRange" type="double" value="0.5" />
    <param name="goalX" type="double" value="$(arg goalX)" />
    <param name="goalY" type="double" value="$(arg goalY)" />
  </node>

  <node pkg="local_planner" type="pathFollower" name="pathFollower" output="screen" required="true">
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <param name="sensorOffsetX" value="$(arg sensorOffsetX)" />
    <param name="sensorOffsetY" value="$(arg sensorOffsetY)" />
    <param name="pubSkipNum" type="int" value="1" />
    <param name="twoWayDrive" value="$(arg twoWayDrive)" />
    <param name="lookAheadDis" type="double" value="$(arg lookAheadDis)" />
    <param name="yawRateGain" type="double" value="7.5" />
    <param name="stopYawRateGain" type="double" value="7.5" />
    <param name="maxYawRate" type="double" value="$(arg maxYawRate)" />
    <param name="maxSpeed" value="$(arg maxSpeed)" />
    <param name="maxAccel" type="double" value="$(arg maxAccel)" />
    <param name="switchTimeThre" type="double" value="1.0" />
    <param name="dirDiffThre" type="double" value="$(arg dirDiffThre)" />
    <param name="stopDisThre" type="double" value="$(arg stopDisThre)" />
    <param name="slowDwnDisThre" type="double" value="$(arg slowDwnDisThre)" />
    <param name="useInclRateToSlow" type="bool" value="false" />
    <param name="inclRateThre" type="double" value="120.0" />
    <param name="slowRate1" type="double" value="0.25" />
    <param name="slowRate2" type="double" value="0.5" />
    <param name="slowTime1" type="double" value="2.0" />
    <param name="slowTime2" type="double" value="2.0" />
    <param name="useInclToStop" type="bool" value="false" />
    <param name="inclThre" type="double" value="45.0" />
    <param name="stopTime" type="double" value="5.0" />
    <param name="noRotAtStop" type="bool" value="$(arg noRotAtStop)" />
    <param name="noRotAtGoal" type="bool" value="$(arg noRotAtGoal)" />
    <param name="autonomyMode" value="$(arg autonomyMode)" />
    <param name="autonomySpeed" value="$(arg autonomySpeed)" />
    <param name="joyToSpeedDelay" value="$(arg joyToSpeedDelay)" />
  </node>

</launch>
